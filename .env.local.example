# AI Configuration (Required for AI Knowledge Engine)
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key_here

# Database Configuration
DATABASE_URL="your_database_url_here"
DIRECT_URL="your_direct_database_url_here"

# Authentication
NEXTAUTH_SECRET="your_nextauth_secret_here"
NEXTAUTH_URL="http://localhost:3000"

# External APIs
OPENAI_API_KEY="your_openai_api_key_here" # Optional, for fallback
ANTHROPIC_API_KEY="your_anthropic_api_key_here" # Optional, for fallback

# Logging and Monitoring
SENTRY_DSN="your_sentry_dsn_here" # Optional, for error tracking

# Development
NODE_ENV="development"